    return InlineKeyboardMarkup([
        [InlineKeyboardButton("📈 Trading", callback_data='trading')],
        [InlineKeyboardButton("🤖 AI",      callback_data='ai_menu')],
        [InlineKeyboardButton("🎬 Shorts",  callback_data='shorts')],
        [InlineKeyboardButton("ℹ️ Help",    callback_data='help')],
    ])


def trading_menu_keyboard():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("💰 Баланс",         callback_data='balance')],
        [InlineKeyboardButton("📋 Последние сделки", callback_data='last_trades')],
        [InlineKeyboardButton("📊 Статистика",      callback_data='stats')],
        [InlineKeyboardButton("✏️ Комментарий",     callback_data='comment')],
        [InlineKeyboardButton("🧠 AI-анализ",       callback_data='ai_analysis')],
        [InlineKeyboardButton("🔙 Назад",           callback_data='back_main')],
    ])


def back_to_trading_keyboard():
    return InlineKeyboardMarkup([
        [InlineKeyboardButton("🔙 В Trading", callback_data='trading')],
        [InlineKeyboardButton("🏠 Главное меню", callback_data='back_main')],
    ])


# ─── Хендлеры ─────────────────────────────────────────────────────────────────

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Команда /start — показать главное меню."""
    text = (
        "👋 *AI Helper Bot*\n\n"
        "Твой помощник трейдера.\n"
        "Отслеживаю сделки, веду дневник, считаю статистику."
    )
    await update.message.reply_text(text, parse_mode='Markdown', reply_markup=main_menu_keyboard())


async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик всех inline-кнопок."""
    query = update.callback_query
    await query.answer()
    data = query.data

    # Главное меню
    if data == 'back_main':
        await query.edit_message_text(
            "🏠 *Главное меню*\nВыбери раздел:",
            parse_mode='Markdown',
            reply_markup=main_menu_keyboard()
        )

    # Trading раздел
    elif data == 'trading':
        await query.edit_message_text(
            "📈 *Trading*\nВыбери действие:",
            parse_mode='Markdown',
            reply_markup=trading_menu_keyboard()
        )

    # Баланс
    elif data == 'balance':
        await query.edit_message_text("⏳ Получаю баланс...", parse_mode='Markdown')
        result = get_balance()
        if result.get('success'):
            text = (
                f"💰 *Баланс аккаунта*\n\n"
                f"📊 Эквити: ${result['equity']:.2f} USDT\n"
                f"✅ Доступно: ${result['available']:.2f} USDT\n"
                f"🔒 Использовано: ${result['used_margin']:.2f} USDT\n"
                f"📈 Нереализованный PNL: ${result['unrealized_pnl']:+.2f} USDT"
            )
        else:
            text = f"❌ Ошибка получения баланса:\n`{result.get('error', 'Неизвестная ошибка')}`"
        await query.edit_message_text(text, parse_mode='Markdown', reply_markup=back_to_trading_keyboard())

    # Последние сделки
    elif data == 'last_trades':
        await query.edit_message_text("⏳ Загружаю сделки...", parse_mode='Markdown')

        open_trades = get_open_trades()
        closed_trades = get_closed_trades()[-5:]

        lines = ["📋 *Последние сделки*\n"]

        if open_trades:
            lines.append("🔓 *Открытые позиции:*")
            for t in open_trades:
                pnl = float(t.get('unrealizedPnl', 0))
                emoji = "🟢" if pnl >= 0 else "🔴"
                lines.append(
                    f"{emoji} {t.get('symbol')} {t.get('side')} | "
                    f"Вход: ${float(t.get('entryPrice', 0)):.4f} | "
                    f"PNL: ${pnl:+.2f}"
                )
        else:
            lines.append("🔓 Открытых позиций нет")

        if closed_trades:
            lines.append("\n✅ *Последние закрытые:*")
            for t in reversed(closed_trades):
                pnl = float(t.get('realizedPnl', t.get('pnl', 0)))
                emoji = "✅" if pnl >= 0 else "❌"
                comment = f"\n   💬 {t['comment']}" if t.get('comment') else ""
                lines.append(
                    f"{emoji} {t.get('symbol')} | PNL: ${pnl:+.2f}{comment}"
                )
        else:
            lines.append("\n✅ Закрытых сделок нет")

        text = "\n".join(lines)
        await query.edit_message_text(text, parse_mode='Markdown', reply_markup=back_to_trading_keyboard())

    # Статистика
    elif data == 'stats':
        await query.edit_message_text("⏳ Считаю статистику...", parse_mode='Markdown')
        stats = calculate_stats()
        text = format_stats_message(stats)
        await query.edit_message_text(text, parse_mode='Markdown', reply_markup=back_to_trading_keyboard())

    # Комментарий — начало диалога
    elif data == 'comment':
        trades = get_trades_for_comment()
        if not trades:
            await query.edit_message_text(
                "📝 Нет сделок для комментария.\nСначала нужно открыть или закрыть позицию.",
                reply_markup=back_to_trading_keyboard()
            )
            return

        buttons = []
        for t in trades[:8]:  # Максимум 8 сделок
            buttons.append([InlineKeyboardButton(t['label'], callback_data=f"sel_trade_{t['orderId']}")])
        buttons.append([InlineKeyboardButton("🔙 Назад", callback_data='trading')])

        await query.edit_message_text(
            "✏️ *Выбери сделку для комментария:*",
            parse_mode='Markdown',
            reply_markup=InlineKeyboardMarkup(buttons)
        )

    # Выбор сделки для комментария
    elif data.startswith('sel_trade_'):
        order_id = data.replace('sel_trade_', '')
        context.user_data['comment_order_id'] = order_id
        await query.edit_message_text(
            f"✏️ *Напиши комментарий* к сделке `{order_id}`:\n\n"
            "Например:\n"
            "• Почему вошел\n"
            "• Что пошло не так\n"
            "• Что узнал из этой сделки",
            parse_mode='Markdown',
            reply_markup=InlineKeyboardMarkup([[
                InlineKeyboardButton("❌ Отмена", callback_data='trading')
            ]])
        )
        context.user_data['waiting_comment'] = True

    # AI-анализ
    elif data == 'ai_analysis':
        await query.edit_message_text("🤖 Анализирую...", parse_mode='Markdown')
        text = get_ai_analysis()
        await query.edit_message_text(text, parse_mode='Markdown', reply_markup=back_to_trading_keyboard())

    # AI меню
    elif data == 'ai_menu':
        await query.edit_message_text(
            "🤖 *AI раздел*\n\nВ разработке. Пока доступен базовый анализ через Trading → AI-анализ.",
            parse_mode='Markdown',
            reply_markup=InlineKeyboardMarkup([[
                InlineKeyboardButton("🔙 Назад", callback_data='back_main')
            ]])
        )

    # Shorts
    elif data == 'shorts':
        await query.edit_message_text(
            "🎬 *Shorts*\n\nРаздел в разработке.",
            parse_mode='Markdown',
            reply_markup=InlineKeyboardMarkup([[
                InlineKeyboardButton("🔙 Назад", callback_data='back_main')
            ]])
        )

    # Help
    elif data == 'help':
        text = (
            "ℹ️ *Помощь*\n\n"
            "📈 *Trading* — работа со сделками:\n"
            "  • 💰 Баланс — текущий баланс BingX\n"
            "  • 📋 Сделки — открытые и закрытые позиции\n"
            "  • 📊 Статистика — Win Rate, PNL и др.\n"
            "  • ✏️ Комментарий — дневник трейдера\n"
            "  • 🧠 AI-анализ — анализ торговли\n\n"
            "🔄 Бот автоматически проверяет новые сделки каждые 60 секунд.\n\n"
            "📌 *Команды:*\n"
            "/start — главное меню\n"
            "/sync — ручная синхронизация"
        )
        await query.edit_message_text(
            text, parse_mode='Markdown',
            reply_markup=InlineKeyboardMarkup([[
                InlineKeyboardButton("🔙 Назад", callback_data='back_main')
            ]])
        )


async def text_message_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик текстовых сообщений (для ввода комментария)."""
    if context.user_data.get('waiting_comment'):
        order_id = context.user_data.get('comment_order_id')
        comment = update.message.text.strip()

        if order_id and comment:
            success = save_comment(order_id, comment)
            if success:
                await update.message.reply_text(
                    f"✅ Комментарий сохранён для сделки `{order_id}`!",
                    parse_mode='Markdown',
                    reply_markup=back_to_trading_keyboard()
                )
            else:
                await update.message.reply_text(
                    "❌ Сделка не найдена. Попробуй снова.",
                    reply_markup=back_to_trading_keyboard()
                )
        context.user_data['waiting_comment'] = False
        context.user_data['comment_order_id'] = None
    else:
        await update.message.reply_text(
            "Используй кнопки меню 👇",
            reply_markup=main_menu_keyboard()
        )


async def sync_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Команда /sync — ручная синхронизация сделок."""
    msg = await update.message.reply_text("🔄 Синхронизирую сделки с BingX...")
    results = await sync_trades(context.bot, update.effective_chat.id)
    new_open = len(results.get('new_open', []))
    new_closed = len(results.get('new_closed', []))
    await msg.edit_text(
        f"✅ Синхронизация завершена!\n\n"
        f"🆕 Новых позиций: {new_open}\n"
        f"🔒 Закрыто позиций: {new_closed}"
    )


async def auto_sync_job(context: ContextTypes.DEFAULT_TYPE):
    """Фоновая задача автосинхронизации."""
    if not CHAT_ID:
        logger.warning("TELEGRAM_CHAT_ID не задан, авто-синхронизация пропущена")
        return
    try:
        await sync_trades(context.bot, CHAT_ID)
    except Exception as e:
        logger.error(f"Ошибка авто-синхронизации: {e}")


# ─── Запуск ───────────────────────────────────────────────────────────────────

def main():
    if not BOT_TOKEN:
        raise ValueError("TELEGRAM_BOT_TOKEN не задан! Проверь .env файл.")

    app = Application.builder().token(BOT_TOKEN).build()

    # Хендлеры команд
    app.add_handler(CommandHandler('start', start))
    app.add_handler(CommandHandler('sync', sync_command))

    # Хендлер кнопок
    app.add_handler(CallbackQueryHandler(button_handler))

    # Хендлер текста (комментарии)
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, text_message_handler))

    # Авто-синхронизация каждые 60 секунд
    app.job_queue.run_repeating(auto_sync_job, interval=60, first=10)

    logger.info("Бот запущен!")
    app.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == '__main__':
    main()
