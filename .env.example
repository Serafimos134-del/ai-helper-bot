# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# BingX API
BINGX_API_KEY=your_api_key_here
BINGX_SECRET_KEY=your_secret_key_here

# AI Provider (Groq)
GROQ_API_KEY=your_groq_key_here

# Proxy (опционально)
# HTTP_PROXY=socks5://user:pass@host:port
# HTTPS_PROXY=socks5://user:pass@host:port

# База данных (опционально, по умолчанию SQLite)
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_helper_bot

# Ключ шифрования для API-ключей BingX в БД (обязателен для продакшена).
# Сгенерировать: python -c "from services.crypto_utils import generate_key; print(generate_key())"
DB_ENCRYPTION_KEY=

# Webhook деплоя (webhook_server.py)
# WEBHOOK_SECRET=
# WEBHOOK_EXPECTED_REPO=Serafimos134-del/ai-helper-bot
# WEBHOOK_SKIP_IP_CHECK=0

# Crypto Pay (@CryptoBot) — оплата подписки, обязателен для /subscribe.
# Получить: @CryptoBot → Crypto Pay → Create App → токен приложения.
# Цена/срок подписки и триала — core/billing.py.
CRYPTO_PAY_TOKEN=